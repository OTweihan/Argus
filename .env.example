# Argus 运行配置示例。复制为 .env 后按需修改。
#
# 每个变量行末注释 (default) 标明的值必须与代码常量 / ServerSettings 默认值一致；
# tests/unit/test_env_example.py 把"example ≡ constants"作为不变式锁住，
# 防止常量演化后此文件出现漂移。注释掉的变量（以 # 开头）不参与检测。

# ─── 浏览器 ───────────────────────────────────────────────
# 浏览器是否以 headless 模式运行（无窗口）。
BROWSER_HEADLESS=false
# Playwright 浏览器类型：chromium / firefox / webkit。
BROWSER_TYPE=chromium

# ─── 任务执行 ─────────────────────────────────────────────
# 黑盒任务的最大动作步数。
MAX_STEPS=20
# 黑盒任务的超时时间（秒）。
TASK_TIMEOUT_S=300

# ─── 产物输出 ─────────────────────────────────────────────
# 报告 / 日志 / 截图 / 临时文件的根目录；相对路径相对于项目根。
OUTPUT_DIR=outputs

# ─── LLM ─────────────────────────────────────────────────
# **必填**：LLM 服务的 API Key。
#   推荐通过 `argus config llm` 命令以加密形式写入数据库，避免明文落盘；
#   此处仅作为开发/调试时的快速覆盖入口。
LLM_API_KEY=
# OpenAI 兼容服务的 base URL（不带尾斜杠）。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM 模型名称。
LLM_MODEL=qwen3.5-plus

# ─── LLM Trace（可观测） ─────────────────────────────────
# 是否启用 LLM 调用追踪文件落盘。
LLM_TRACE_ENABLED=true
# 单个 trace 文件大小上限（MB）。
LLM_TRACE_MAX_SIZE_MB=50
# trace 内容是否脱敏（api_key / cookie / token 等敏感字段被替换为 ***）。
LLM_TRACE_CONTENT_REDACT=true

# ─── 高级 / 调试（默认无需设置） ──────────────────────────
# HTTP 代理，例如 http://user:pass@host:port。
# LLM_HTTPX_PROXY=
# 是否允许 httpx 读取系统 HTTP(S)_PROXY 环境变量。
# LLM_HTTPX_TRUST_ENV=true
# 覆盖项目根目录（默认按代码自动推断）。
# ARGUS_PROJECT_ROOT=
# 覆盖 server.yaml 路径（默认 config/server.yaml）。
# ARGUS_SERVER_CONFIG=config/server.yaml
