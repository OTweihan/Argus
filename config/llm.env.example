LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# LLM Trace（覆盖 config/server.yaml observability.llm_trace.*）
LLM_TRACE_ENABLED=true
LLM_TRACE_MAX_SIZE_MB=10
LLM_TRACE_CONTENT_REDACT=true
