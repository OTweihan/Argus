# 防止 docker build context 把无关大文件 / 敏感文件复制进镜像

# Python venv / 构建产物
.venv/
**/.venv/
build/
dist/
**/*.egg-info/
**/__pycache__/
**/*.pyc

# 前端 node_modules / 缓存（multi-stage 内 pnpm install 后会生成）
frontend/node_modules/
frontend/dist/
frontend/.vite/

# 测试与覆盖率产物
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage*

# 运行时输出（DB、screenshots 等通过 volume 持久化，不入镜像）
outputs/

# IDE / 系统垃圾
.vscode/
.idea/
.DS_Store
Thumbs.db

# git 元数据（运行时不需要）
.git/
.gitignore
.gitattributes
.github/

# CI / agent transcripts / gitnexus 索引
.claude/
.gitnexus/
.cursor/
agent-transcripts/
terminals/

# 敏感文件（即使 dockerignore 也不应进镜像，靠 volume mount 注入）
config/.fernet_key
config/llm.env

# 文档（非运行依赖）
docs/
*.md
!README.md
