<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report.title }}</title>
  <style>
    :root {
      color-scheme: light;
      --page-bg: #f3f6fb;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --text: #172033;
      --muted: #667085;
      --muted-2: #98a2b3;
      --line: #e4e7ec;
      --line-strong: #d0d5dd;
      --primary: #4f46e5;
      --primary-soft: #eef2ff;
      --success: #15803d;
      --success-soft: #ecfdf3;
      --danger: #b42318;
      --danger-soft: #fff1f3;
      --warning: #b54708;
      --warning-soft: #fffaeb;
      --info: #175cd3;
      --info-soft: #eff8ff;
      --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
      --radius-lg: 20px;
      --radius-md: 14px;
      --radius-sm: 10px;
      --mono: Consolas, Monaco, "SFMono-Regular", monospace;
      --font: Inter, "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
    }

    * { box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      background: #ffffff;
      color: var(--text);
      font-family: var(--font);
      font-size: 14px;
      line-height: 1.65;
    }

    a { color: inherit; }

    code {
      padding: 2px 6px;
      border: 1px solid var(--line);
      border-radius: 7px;
      background: #f2f4f7;
      color: #344054;
      font-family: var(--mono);
      font-size: 12px;
    }

    .page {
      width: min(1200px, calc(100% - 40px));
      margin: 0 auto;
      padding: 28px 0 44px;
    }

    .report-hero {
      overflow: hidden;
      position: relative;
      border: 1px solid rgba(255, 255, 255, 0.7);
      border-radius: 28px;
      background:
        linear-gradient(135deg, rgba(23, 32, 51, 0.96), rgba(49, 46, 129, 0.94)),
        #111827;
      box-shadow: var(--shadow);
      color: #ffffff;
    }

    .report-hero::after {
      content: "";
      position: absolute;
      right: -160px;
      top: -160px;
      width: 360px;
      height: 360px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 28px;
      padding: 34px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      color: #c7d2fe;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 6px rgba(34, 197, 94, 0.18);
    }

    h1, h2, h3 {
      margin: 0;
      line-height: 1.25;
    }

    h1 {
      font-size: clamp(28px, 4vw, 42px);
      letter-spacing: -0.04em;
    }

    h2 {
      font-size: 21px;
      letter-spacing: -0.02em;
    }

    h3 { font-size: 16px; }

    p { margin: 6px 0; }

    .hero-desc {
      max-width: 760px;
      margin-top: 12px;
      color: #dbe4ff;
      font-size: 15px;
    }

    .hero-meta {
      display: grid;
      gap: 10px;
      min-width: 290px;
      padding: 18px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(16px);
    }

    .meta-row {
      display: grid;
      grid-template-columns: 84px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
    }

    .meta-label {
      color: #c7d2fe;
      font-size: 12px;
    }

    .meta-value {
      overflow-wrap: anywhere;
      color: #ffffff;
      font-family: var(--mono);
      font-size: 12px;
    }

    .hero-status {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .layout {
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 22px;
      margin-top: 22px;
      align-items: start;
    }

    .sidebar {
      position: sticky;
      top: 18px;
      display: grid;
      gap: 14px;
    }

    .nav-card, .card {
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.86);
      box-shadow: 0 10px 32px rgba(15, 23, 42, 0.05);
      backdrop-filter: blur(18px);
    }

    .nav-card { padding: 14px; }

    .nav-title {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .nav-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 9px 10px;
      border-radius: 11px;
      color: #344054;
      text-decoration: none;
    }

    .nav-link:hover {
      background: var(--primary-soft);
      color: var(--primary);
    }

    .nav-link span:last-child {
      color: var(--muted-2);
      font-size: 12px;
    }

    .content {
      display: grid;
      gap: 18px;
    }

    .section { scroll-margin-top: 20px; }

    .section-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: flex-end;
      margin: 0 0 12px;
    }

    .section-subtitle {
      margin-top: 5px;
      color: var(--muted);
    }

    .card { padding: 20px; }

    .metrics {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 14px;
      margin-top: -10px;
    }

    .metric {
      position: relative;
      overflow: hidden;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: #ffffff;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
    }

    .metric::after {
      content: "";
      position: absolute;
      right: -22px;
      bottom: -22px;
      width: 74px;
      height: 74px;
      border-radius: 999px;
      background: var(--primary-soft);
    }

    .metric span {
      position: relative;
      z-index: 1;
      display: block;
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
    }

    .metric strong {
      position: relative;
      z-index: 1;
      display: block;
      margin-top: 6px;
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: -0.04em;
    }

    .metric .badge { margin-top: 2px; }

    .info-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--panel);
    }

    .info-table tr:not(:last-child) th,
    .info-table tr:not(:last-child) td {
      border-bottom: 1px solid var(--line);
    }

    .info-table th,
    .info-table td {
      padding: 12px 14px;
      text-align: left;
      vertical-align: top;
    }

    .info-table th {
      width: 150px;
      background: var(--panel-soft);
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
      white-space: nowrap;
    }

    .info-table td { overflow-wrap: anywhere; }

    .badge {
      display: inline-flex;
      min-width: 76px;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 4px 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.3;
      white-space: nowrap;
    }

    .badge::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: currentColor;
    }

    .success, .completed {
      color: var(--success);
      border-color: #bbf7d0;
      background: var(--success-soft);
    }

    .failed, .error, .critical, .high {
      color: var(--danger);
      border-color: #fecdd3;
      background: var(--danger-soft);
    }

    .timeout, .medium {
      color: var(--warning);
      border-color: #fedf89;
      background: var(--warning-soft);
    }

    .info, .low, .running, .pending {
      color: var(--info);
      border-color: #b2ddff;
      background: var(--info-soft);
    }

    .timeline {
      position: relative;
      display: grid;
      gap: 14px;
    }

    .timeline::before {
      content: "";
      position: absolute;
      left: 24px;
      top: 18px;
      bottom: 18px;
      width: 2px;
      background: linear-gradient(180deg, var(--primary), rgba(79, 70, 229, 0.08));
    }

    .step {
      position: relative;
      margin-left: 52px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--panel);
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .step::before {
      content: attr(data-step);
      position: absolute;
      left: -52px;
      top: 18px;
      z-index: 1;
      display: grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border: 3px solid #ffffff;
      border-radius: 999px;
      background: var(--primary);
      color: #ffffff;
      box-shadow: 0 8px 20px rgba(79, 70, 229, 0.28);
      font-size: 12px;
      font-weight: 800;
    }

    .step.result-failed {
      border-color: #fecdd3;
      box-shadow: 0 10px 28px rgba(180, 35, 24, 0.08);
    }

    .step.result-failed::before {
      background: var(--danger);
      box-shadow: 0 8px 20px rgba(180, 35, 24, 0.24);
    }

    .step-head, .finding-head {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
      padding: 18px 18px 0;
      margin-bottom: 12px;
    }

    .step-title {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .action-pill {
      display: inline-flex;
      align-items: center;
      padding: 3px 8px;
      border-radius: 999px;
      background: var(--primary-soft);
      color: var(--primary);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
    }

    .muted { color: var(--muted); }

    .step-body { padding: 0 18px 18px; }

    details {
      overflow: hidden;
      margin-top: 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: #ffffff;
    }

    summary {
      cursor: pointer;
      padding: 11px 13px;
      background: var(--panel-soft);
      color: var(--text);
      font-weight: 700;
      user-select: none;
    }

    summary:hover { background: #eef2ff; }

    .params {
      margin: 0;
      padding: 13px;
      overflow-x: auto;
      border-top: 1px solid var(--line);
      background: #0f172a;
      color: #e2e8f0;
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.7;
      white-space: pre-wrap;
    }

    .screenshot-wrap { padding: 0 13px 13px; }

    .screenshot-path {
      margin: 12px 0;
      color: var(--muted);
      font-size: 12px;
      overflow-wrap: anywhere;
    }

    .screenshot-link {
      display: block;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: #ffffff;
    }

    .screenshot {
      display: block;
      width: 100%;
      max-height: 520px;
      object-fit: contain;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 20;
      padding: 28px;
      background: rgba(15, 23, 42, 0.88);
      text-align: center;
    }

    .lightbox:target {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }

    .lightbox img {
      max-width: min(96vw, 1440px);
      max-height: 86vh;
      border: 1px solid #ffffff;
      border-radius: var(--radius-md);
      background: #ffffff;
      object-fit: contain;
    }

    .lightbox-close {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: #ffffff;
      color: #111827;
      text-decoration: none;
      font-weight: 800;
    }

    .empty-state {
      display: grid;
      place-items: center;
      min-height: 140px;
      border: 1px dashed var(--line-strong);
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.72);
      color: var(--muted);
      text-align: center;
    }

    .empty-state strong {
      display: block;
      margin-bottom: 4px;
      color: var(--text);
      font-size: 16px;
    }

    .failure-summary {
      margin-bottom: 14px;
    }

    .failure-summary .info-table {
      margin-top: 12px;
    }

    .err-code {
      display: inline-block;
      margin-left: 8px;
      padding: 2px 8px;
      border-radius: 6px;
      background: var(--danger-soft);
      color: var(--danger);
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 600;
    }

    .footer-note {
      margin-top: 22px;
      color: var(--muted);
      text-align: center;
      font-size: 12px;
    }

    .flow-card { margin-top: 10px; }

    .flow-card summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .flow-tree {
      padding: 8px 12px 12px;
      border-top: 1px solid var(--line);
    }

    .flow-step {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
      font-size: 13px;
    }

    .flow-step + .flow-step {
      border-top: 1px dashed var(--line);
    }

    .flow-depth-indicator {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 20px;
      height: 20px;
      border-radius: 99px;
      background: var(--primary-soft);
      color: var(--primary);
      font-size: 11px;
      font-weight: 700;
    }

    .clusters-grid {
      display: grid;
      gap: 10px;
    }

    .cluster-card { margin-top: 0; }

    .cluster-card summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .cluster-members {
      margin: 0;
      padding: 10px 14px;
      border-top: 1px solid var(--line);
      list-style: none;
    }

    .cluster-members li {
      padding: 3px 0;
      font-size: 13px;
    }

    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; }
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      .nav-card { display: none; }
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 720px) {
      .page {
        width: min(100% - 24px, 1200px);
        padding-top: 12px;
      }

      .hero-inner { padding: 22px; }
      .hero-meta { min-width: 0; }
      .metrics { grid-template-columns: 1fr; }

      .section-head,
      .step-head,
      .finding-head {
        display: grid;
      }

      .info-table,
      .info-table tbody,
      .info-table tr,
      .info-table th,
      .info-table td {
        display: block;
        width: 100%;
      }

      .info-table th { border-bottom: 0 !important; }
      .timeline::before { left: 17px; }
      .step { margin-left: 42px; }

      .step::before {
        left: -42px;
        width: 28px;
        height: 28px;
        font-size: 11px;
      }
    }
  </style>
</head>
<body>
<div class="page">
  {% block content %}{% endblock %}
  <p class="footer-note">Generated by Argus · Blackbox Test Agent Report</p>
</div>
</body>
</html>
