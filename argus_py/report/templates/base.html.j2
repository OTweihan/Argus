<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report.title }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f7f8fa;
      --panel: #ffffff;
      --text: #1f2933;
      --muted: #697586;
      --line: #d9dee7;
      --ok: #157f3b;
      --bad: #ba2f2f;
      --warn: #9a6700;
      --info: #1f5fbf;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, "Microsoft YaHei", sans-serif;
      font-size: 14px;
      line-height: 1.55;
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 24px;
    }
    header {
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
    }
    h1, h2, h3 { margin: 0; line-height: 1.25; }
    h1 { font-size: 28px; }
    h2 { margin: 28px 0 12px; font-size: 20px; }
    h3 { margin: 0 0 8px; font-size: 16px; }
    p { margin: 6px 0; }
    code {
      padding: 2px 5px;
      border: 1px solid var(--line);
      border-radius: 4px;
      background: #f2f4f7;
      font-family: Consolas, monospace;
      font-size: 12px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--panel);
      border: 1px solid var(--line);
    }
    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }
    th {
      width: 160px;
      color: var(--muted);
      background: #f4f6f8;
      font-weight: 600;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }
    .metric {
      padding: 14px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 6px;
    }
    .metric span {
      display: block;
      color: var(--muted);
      font-size: 12px;
    }
    .metric strong {
      display: block;
      margin-top: 4px;
      font-size: 20px;
    }
    .timeline {
      display: grid;
      gap: 12px;
    }
    .step, .finding {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 14px;
    }
    .step-head, .finding-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 10px;
    }
    .muted { color: var(--muted); }
    .badge {
      display: inline-block;
      min-width: 72px;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      text-align: center;
      font-size: 12px;
      white-space: nowrap;
    }
    .success, .completed { color: var(--ok); border-color: #9ed8b2; background: #edf9f1; }
    .failed, .error, .critical, .high { color: var(--bad); border-color: #f1b4b4; background: #fff1f1; }
    .timeout, .medium { color: var(--warn); border-color: #e7c26b; background: #fff8e6; }
    .info, .low, .running, .pending { color: var(--info); border-color: #aac3ee; background: #eef5ff; }
    .params {
      margin-top: 8px;
      padding: 10px;
      overflow-x: auto;
      background: #f7f8fa;
      border: 1px solid var(--line);
      border-radius: 4px;
      font-family: Consolas, monospace;
      font-size: 12px;
      white-space: pre-wrap;
    }
    .screenshot {
      margin-top: 10px;
      max-width: 100%;
      border: 1px solid var(--line);
      border-radius: 4px;
      background: #fff;
    }
    @media (max-width: 820px) {
      main { padding: 16px; }
      .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .step-head, .finding-head { display: block; }
      th { width: 120px; }
    }
  </style>
</head>
<body>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
